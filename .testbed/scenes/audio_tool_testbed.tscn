[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/audio_tool_testbed.gd" id="1_script"]

[node name="AudioToolTestbed" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_script")

[node name="MarginContainer" type="MarginContainer" parent="."]
